@prefix cred: <https://www.w3.org/2018/credentials#>.
@prefix fibo-be-oac-exec: <https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/Executives/>.
@prefix kyb: <https://solid-kyb-vocab.vercel.app/kyb#>.
@prefix schema: <https://schema.org/>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

<https://northwind.pod.example/kyb/credentials/officer-authorization> a cred:VerifiableCredential, kyb:OfficerAuthorizationCredential;
    cred:issuer <https://issuers.example/orgs/org-identity-registrar#id>;
    cred:validFrom "2026-05-23T12:00:00.000Z"^^xsd:dateTime;
    cred:validUntil "2027-05-23T12:00:00.000Z"^^xsd:dateTime;
    cred:credentialStatus <https://issuers.example/status/officer-authorization#3>;
    cred:credentialSubject <https://northwind.pod.example/profile/card#me>.
<https://northwind.pod.example/profile/card#me>
    kyb:hasAuthorizedOfficer _:officer.
_:officer a fibo-be-oac-exec:Signatory, fibo-be-oac-exec:CorporateOfficer, schema:Person;
    schema:name "Jordan Blake";
    schema:jobTitle "Managing Member & CEO";
    fibo-be-oac-exec:hasSigningAuthorityFor <https://northwind.pod.example/profile/card#me>;
    fibo-be-oac-exec:isOfficerOf <https://northwind.pod.example/profile/card#me>.
