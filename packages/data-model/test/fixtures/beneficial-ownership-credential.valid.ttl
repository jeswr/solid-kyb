@prefix cred: <https://www.w3.org/2018/credentials#>.
@prefix cmns-org: <https://www.omg.org/spec/Commons/Organizations/>.
@prefix fibo-be-oac-opty: <https://spec.edmcouncil.org/fibo/ontology/BE/OwnershipAndControl/OwnershipParties/>.
@prefix fibo-be-le-lei: <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LEIEntities/>.
@prefix kyb: <https://solid-kyb-vocab.vercel.app/kyb#>.
@prefix schema: <https://schema.org/>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

<https://northwind.pod.example/kyb/credentials/beneficial-ownership> a cred:VerifiableCredential, kyb:BeneficialOwnershipCredential;
    cred:issuer <https://issuers.example/orgs/beneficial-ownership-registrar#id>;
    cred:validFrom "2026-05-23T12:00:00.000Z"^^xsd:dateTime;
    cred:validUntil "2027-05-23T12:00:00.000Z"^^xsd:dateTime;
    cred:credentialStatus <https://issuers.example/status/beneficial-ownership#7>;
    cred:credentialSubject <https://northwind.pod.example/profile/card#me>.
<https://northwind.pod.example/profile/card#me>
    kyb:hasOwnershipRecord _:ownership0, _:ownership1, _:ownership2, _:ownership3.
_:ownership0 a fibo-be-oac-opty:EntityOwnership;
    fibo-be-oac-opty:hasOwningEntity _:owner0;
    fibo-be-oac-opty:hasOwnedEntity <https://northwind.pod.example/profile/card#me>;
    fibo-be-le-lei:hasOwnershipPercentage "42.0"^^xsd:decimal;
    kyb:ownershipPercentageBps 4200.
_:owner0 a fibo-be-oac-opty:EntityOwner, cmns-org:LegalPerson, schema:Person;
    schema:name "Jordan Blake".
_:ownership1 a fibo-be-oac-opty:EntityOwnership;
    fibo-be-oac-opty:hasOwningEntity _:owner1;
    fibo-be-oac-opty:hasOwnedEntity <https://northwind.pod.example/profile/card#me>;
    fibo-be-le-lei:hasOwnershipPercentage "28.0"^^xsd:decimal;
    kyb:ownershipPercentageBps 2800.
_:owner1 a fibo-be-oac-opty:EntityOwner, cmns-org:LegalPerson, schema:Person;
    schema:name "Priya Nandakumar".
_:ownership2 a fibo-be-oac-opty:EntityOwnership;
    fibo-be-oac-opty:hasOwningEntity _:owner2;
    fibo-be-oac-opty:hasOwnedEntity <https://northwind.pod.example/profile/card#me>;
    fibo-be-le-lei:hasOwnershipPercentage "18.0"^^xsd:decimal;
    kyb:ownershipPercentageBps 1800.
_:owner2 a fibo-be-oac-opty:EntityOwner, cmns-org:LegalPerson, schema:Person;
    schema:name "Marcus Webb".
_:ownership3 a fibo-be-oac-opty:EntityOwnership;
    fibo-be-oac-opty:hasOwningEntity _:owner3;
    fibo-be-oac-opty:hasOwnedEntity <https://northwind.pod.example/profile/card#me>;
    fibo-be-le-lei:hasOwnershipPercentage "12.0"^^xsd:decimal;
    kyb:ownershipPercentageBps 1200.
_:owner3 a fibo-be-oac-opty:EntityOwner, cmns-org:LegalPerson, schema:Person;
    schema:name "Dana Reyes".
