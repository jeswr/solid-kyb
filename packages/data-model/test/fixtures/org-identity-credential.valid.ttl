@prefix cred: <https://www.w3.org/2018/credentials#>.
@prefix cmns-id: <https://www.omg.org/spec/Commons/Identifiers/>.
@prefix fibo-be-le-lei: <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LEIEntities/>.
@prefix fibo-be-le-lp: <https://spec.edmcouncil.org/fibo/ontology/BE/LegalEntities/LegalPersons/>.
@prefix kyb: <https://solid-kyb-vocab.vercel.app/kyb#>.
@prefix schema: <https://schema.org/>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.

<https://northwind.pod.example/kyb/credentials/org-identity> a cred:VerifiableCredential, kyb:OrganisationalIdentityCredential;
    cred:issuer <https://issuers.example/orgs/org-identity-registrar#id>;
    cred:validFrom "2026-05-23T12:00:00.000Z"^^xsd:dateTime;
    cred:validUntil "2027-05-23T12:00:00.000Z"^^xsd:dateTime;
    cred:credentialStatus <https://issuers.example/status/org-identity#42>;
    cred:credentialSubject <https://northwind.pod.example/profile/card#me>.
<https://northwind.pod.example/profile/card#me> a fibo-be-le-lei:LEIRegisteredEntity, fibo-be-le-lp:BusinessEntity, schema:Organization;
    schema:name "Northwind Logistics LLC";
    schema:address _:businessAddress;
    cmns-id:isIdentifiedBy _:lei;
    fibo-be-le-lei:hasLegalForm kyb:EntityLegalForm-LLC.
_:businessAddress a schema:PostalAddress;
    schema:streetAddress "1180 Freight Yard Road";
    schema:addressLocality "Kansas City";
    schema:addressRegion "MO";
    schema:postalCode "64105".
_:lei a fibo-be-le-lei:LegalEntityIdentifier;
    schema:identifier "9999NWLOGISTICS00170";
    kyb:isIllustrativeLei true.
